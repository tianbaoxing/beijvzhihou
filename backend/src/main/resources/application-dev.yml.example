spring:
  datasource:
    driver-class-name: com.mysql.cj.jdbc.Driver
    url: jdbc:mysql://localhost:3306/beijvzhihou?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai&useSSL=false
    username: ${DB_USERNAME:your_db_username}
    password: ${DB_PASSWORD:your_db_password}

# Redis 配置（MVP 暂用内存 Map，生产环境请安装 Redis 并取消注释）
  # data:
  #   redis:

  # 邮件配置（后续填入）
  mail:
    host: smtp.qq.com
    port: 587
    username: ${MAIL_USERNAME:your_email_username}
    password: ${MAIL_PASSWORD:your_email_password}
    properties:
      mail:
        smtp:
          auth: true
          starttls:
            enable: true

# MyBatis-Plus 配置
mybatis-plus:
  mapper-locations: classpath*:/mapper/**/*.xml
  type-aliases-package: com.beijvzhihou.entity
  configuration:
    map-underscore-to-camel-case: true
    log-impl: org.apache.ibatis.logging.stdout.StdOutImpl
  global-config:
    db-config:
      id-type: auto
      # 注意：项目使用 Post.status 手动软删除，不启用 MyBatis-Plus 全局逻辑删除
      # 如需对某表启用逻辑删除，在对应 Entity 上加 @TableLogic 注解即可

# 服务器配置
server:
  port: 8080
  servlet:
    encoding:
      charset: UTF-8
      enabled: true
      force: true

# 自定义配置
app:
  jwt:
    # ⚠️ 生产环境必须设置 JWT_SECRET 环境变量，不使用默认值
    secret: ${JWT_SECRET:your_jwt_secret_key_at_least_32_characters}
    expire-days: 7
  email:
    code-expire-minutes: 5

  # AI 配置
  ai:
    emotion-threshold: 2
    deepseek:
      api-key: ${OPENROUTER_API_KEY:your_openrouter_api_key}
      base-url: https://openrouter.ai/api/v1
      model: deepseek/deepseek-v3.2
    kimi2:
      api-key: ${OPENROUTER_API_KEY:your_openrouter_api_key}
      base-url: https://openrouter.ai/api/v1
      model: moonshotai/kimi-k2.6
    qwen:
      api-key: ${OPENROUTER_API_KEY:your_openrouter_api_key}
      base-url: https://openrouter.ai/api/v1
      model: qwen/qwen3.6-plus