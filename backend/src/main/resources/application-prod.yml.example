spring:
  datasource:
    driver-class-name: com.mysql.cj.jdbc.Driver
    url: ${DB_URL:jdbc:mysql://localhost:3306/beijvzhihou?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai&useSSL=true}
    username: ${DB_USERNAME:your_db_username}
    password: ${DB_PASSWORD:your_db_password}

# Redis 配置（生产环境推荐使用 Redis）
  data:
    redis:
      host: ${REDIS_HOST:localhost}
      port: ${REDIS_PORT:6379}
      password: ${REDIS_PASSWORD:}
      database: 0

  # 邮件配置
  mail:
    host: ${MAIL_HOST:smtp.qq.com}
    port: ${MAIL_PORT:587}
    username: ${MAIL_USERNAME:your_email_username}
    password: ${MAIL_PASSWORD:your_email_password}
    properties:
      mail:
        smtp:
          auth: true
          starttls:
            enable: true

# MyBatis-Plus 配置
mybatis-plus:
  mapper-locations: classpath*:/mapper/**/*.xml
  type-aliases-package: com.beijvzhihou.entity
  configuration:
    map-underscore-to-camel-case: true
    log-impl: org.apache.ibatis.logging.slf4j.Slf4jImpl
  global-config:
    db-config:
      id-type: auto

# 服务器配置
server:
  port: ${SERVER_PORT:8080}
  servlet:
    encoding:
      charset: UTF-8
      enabled: true
      force: true

# 日志配置
logging:
  level:
    com.beijvzhihou: INFO
    com.baomidou.mybatisplus: WARN
  file:
    name: ${LOG_PATH:/var/log/beijvzhihou}/application.log

# 自定义配置
app:
  jwt:
    # ⚠️ 生产环境必须设置 JWT_SECRET 环境变量，不使用默认值
    secret: ${JWT_SECRET:}
    expire-days: 7
  email:
    code-expire-minutes: 5

  # AI 配置
  ai:
    emotion-threshold: 2
    deepseek:
      api-key: ${OPENROUTER_API_KEY:}
      base-url: https://openrouter.ai/api/v1
      model: deepseek/deepseek-v3.2
    kimi2:
      api-key: ${OPENROUTER_API_KEY:}
      base-url: https://openrouter.ai/api/v1
      model: moonshotai/kimi-k2.6
    qwen:
      api-key: ${OPENROUTER_API_KEY:}
      base-url: https://openrouter.ai/api/v1
      model: qwen/qwen3.6-plus